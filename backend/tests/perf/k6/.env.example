# Base URL should match your backend runtime. HTTPS may be required because auth cookie is Secure.
BASE_URL=http://localhost:8080
API_VERSION=1

# User fixture CSV path relative to tests/perf/k6
USERS_CSV=../data/users.csv

# Workload controls
VUS=25
DURATION=10m
TRADE_ROWS_PER_FILE=5000

# Mixed profile percentages (must total <=100; remainder is read flow)
MIXED_UPLOAD_PCT=30
MIXED_AUTH_PCT=10

# Think time per flow
UPLOAD_SLEEP_MS=500
READ_SLEEP_MS=200
AUTH_SLEEP_MS=500



